FROM python:3.12-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 8000

CMD ["sh", "-c", "python execution/bootstrap_database.py && python execution/seed_reference_data.py && uvicorn main_backend:app --host 0.0.0.0 --port 8000"]
